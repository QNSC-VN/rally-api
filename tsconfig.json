{
  "compilerOptions": {
    "module": "commonjs",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@shared-kernel": ["./libs/shared-kernel/src/index"],
      "@shared-kernel/*": ["./libs/shared-kernel/src/*"],
      "@platform": ["./libs/platform/src/index"],
      "@platform/*": ["./libs/platform/src/*"],
      "@contracts": ["./libs/contracts/src/index"],
      "@contracts/*": ["./libs/contracts/src/*"],
      "@modules/identity": ["./libs/modules/identity/src/index"],
      "@modules/identity/*": ["./libs/modules/identity/src/*"],
      "@modules/tenancy": ["./libs/modules/tenancy/src/index"],
      "@modules/tenancy/*": ["./libs/modules/tenancy/src/*"],
      "@modules/access": ["./libs/modules/access/src/index"],
      "@modules/access/*": ["./libs/modules/access/src/*"],
      "@modules/projects": ["./libs/modules/projects/src/index"],
      "@modules/projects/*": ["./libs/modules/projects/src/*"],
      "@modules/work-items": ["./libs/modules/work-items/src/index"],
      "@modules/work-items/*": ["./libs/modules/work-items/src/*"],
      "@modules/workflow": ["./libs/modules/workflow/src/index"],
      "@modules/workflow/*": ["./libs/modules/workflow/src/*"],
      "@modules/planning": ["./libs/modules/planning/src/index"],
      "@modules/planning/*": ["./libs/modules/planning/src/*"],
      "@modules/releases": ["./libs/modules/releases/src/index"],
      "@modules/releases/*": ["./libs/modules/releases/src/*"],
      "@modules/collaboration": ["./libs/modules/collaboration/src/index"],
      "@modules/collaboration/*": ["./libs/modules/collaboration/src/*"],
      "@modules/notifications": ["./libs/modules/notifications/src/index"],
      "@modules/notifications/*": ["./libs/modules/notifications/src/*"],
      "@modules/audit": ["./libs/modules/audit/src/index"],
      "@modules/audit/*": ["./libs/modules/audit/src/*"],
      "@modules/reporting": ["./libs/modules/reporting/src/index"],
      "@modules/reporting/*": ["./libs/modules/reporting/src/*"]
    }
  }
}
