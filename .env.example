# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────
# Full DSN including pool limits
DATABASE_URL=postgresql://rally_app:changeme@localhost:5432/rally_dev?sslmode=disable
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Separate privileged URL for migrations (bypasses RLS)
DATABASE_MIGRATION_URL=postgresql://rally_migrate:changeme@localhost:5432/rally_dev?sslmode=disable

# ── Redis / Valkey ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rally:

# ── Auth / JWT ────────────────────────────────────────────────────
# EdDSA key pair (generate: openssl genpkey -algorithm ed25519)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
JWT_ISSUER=rally-api
JWT_AUDIENCE=rally-web

# CSRF secret (min 32 chars)
CSRF_SECRET=change-me-to-a-random-32char-secret

# ── AWS ───────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=000000000000

# LocalStack (dev) — full local AWS, no real account needed.
# docker compose -f docker-compose.dev.yml up -d  ← starts LocalStack and
# automatically creates all queues, topics, and the S3 bucket via the
# init hook (scripts/localstack/init.sh).
# Production resources live in the rally-infra repo (Terraform).
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SNS / SQS — LocalStack ARNs/URLs are deterministic (account = 000000000000)
SNS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:000000000000:rally-domain-events
SQS_NOTIFICATIONS_URL=http://localhost:4566/000000000000/rally-notifications
SQS_AUDIT_URL=http://localhost:4566/000000000000/rally-audit
SQS_REPORTING_URL=http://localhost:4566/000000000000/rally-reporting
SQS_SEARCH_URL=

# S3
S3_ATTACHMENTS_BUCKET=rally-dev-attachments

# ── Observability ─────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=rally-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

LOG_LEVEL=debug
LOG_PRETTY=true
LOG_SQL=false
LOG_HTTP_BODIES=false
LOG_DEV_EMAIL_CONTENT=false

# ── Resilience ────────────────────────────────────────────────────
RESILIENCE_ENABLED=true

# ── SSO / Microsoft Entra ID (optional — leave empty to disable SSO) ──────────
# When set, the API validates Entra ID tokens via JWKS and provisions users JIT.
# ENTRA_TENANT_ID=your-azure-tenant-id
# ENTRA_CLIENT_ID=your-azure-app-client-id
# ENTRA_DEFAULT_TENANT_ID=00000000-0000-7000-8000-000000000001  # tenant UUID for JIT-provisioned users

# ── Email (─────────────────────────────────────────────
EMAIL_PROVIDER=ses
